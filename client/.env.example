# Base URL of the FastAPI backend.
# Local dev: http://localhost:8000
# Production (Vercel): set to your deployed backend URL, e.g. https://dev-sync-backend.onrender.com
VITE_API_BASE_URL=http://localhost:8000

# Supabase project URL and anon key — used by the realtime subscription on the
# `messages` channel in src/lib/supabase-realtime.ts.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
